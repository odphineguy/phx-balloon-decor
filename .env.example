# Tenant selection — must match a tenants/<id>.json file
TENANT_ID=phoenix-balloon-decor

# OpenAI image renders — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_key_here
# Optional model override. Default gpt-image-2 (native high input fidelity).
# Setting gpt-image-1.5 re-enables the explicit input_fidelity=high param.
# OPENAI_IMAGE_MODEL=gpt-image-2

# Supabase lead persistence (server-only — never expose the service role key)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Resend lead notification email
RESEND_API_KEY=re_your_key_here
